# OpenRouter API Key (for LLM-based compression of unknown commands)
# Get your key at: https://openrouter.ai/keys
#
# The daemon will automatically load this file on startup.
# You can also set this as an environment variable.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter Model (optional, defaults to openai/gpt-oss-20b)
# Examples: openai/gpt-4, meta-llama/llama-3-70b, anthropic/claude-3-haiku
# OPENROUTER_MODEL=openai/gpt-oss-20b

# Optional: Daemon log level
# RUST_LOG=debug
